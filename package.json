{
  "name": "opencode-thinking-fix",
  "version": "1.1.6",
  "description": "Fix DeepSeek/Kimi/GLM/MiMo reasoning_content 400 errors in OpenCode. Plugin + proxy + watchdog.",
  "license": "MIT",
  "author": "tbosancheros39",
  "keywords": [
    "opencode",
    "deepseek",
    "kimi",
    "glm",
    "reasoning",
    "reasoning_content",
    "thinking",
    "proxy",
    "plugin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tbosancheros39/opencode-thinking-fix.git"
  },
  "oc-plugin": [
    "server",
    "tui"
  ],
  "main": "./plugins/opencode-thinking-fix-universal.ts",
  "exports": {
    "./server": {
      "import": "./plugins/opencode-thinking-fix-universal.ts",
      "types": "./plugins/opencode-thinking-fix-universal.ts"
    },
    "./tui": {
      "import": "./plugins/opencode-thinking-fix-tui.ts",
      "types": "./plugins/opencode-thinking-fix-tui.ts"
    }
  },
  "files": [
    "plugins/",
    "proxy/",
    "tests/",
    "watchdog/",
    "systemd/",
    "README.md",
    "LICENSE.md",
    ".gitignore"
  ],
  "scripts": {
    "test": "node tests/test-plugin.js && node tests/test-proxy.js"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.3.0"
  }
}
